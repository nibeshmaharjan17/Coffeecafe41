# MongoDB Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/coffeecafe?retryWrites=true&w=majority

# Security
JWT_SECRET=your-very-long-random-secret-key-min-32-chars-generated-securely
JWT_EXPIRATION=24h
REFRESH_TOKEN_EXPIRATION=7d

# Admin Credentials (password must be hashed with bcrypt)
# Generate hash using: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$10$... # Replace with hashed password

# CORS Configuration (comma-separated allowed domains)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Server
PORT=5000
NODE_ENV=production
